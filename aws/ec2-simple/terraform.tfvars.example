# AWS Configuration
aws_region = "us-east-1"
project_name = "goondvr"

# EC2 Instance Configuration
instance_type = "m7i-flex.large"  # Free tier eligible: 2 vCPU, 8 GB RAM
volume_size = 30  # GB

# Network Security
# Restrict to your IP for better security
allowed_cidr_blocks = ["YOUR_IP/32"]  # Example: ["103.185.218.95/32"]

